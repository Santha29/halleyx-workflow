{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Server",
      "type": "shell",
      "command": "uvicorn main:app --reload --port 8080",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Open Browser",
      "type": "shell",
      "command": "start http://localhost:8080",
      "windows": {
        "command": "start http://localhost:8080"
      },
      "group": "test",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Open API Docs",
      "type": "shell",
      "command": "start http://localhost:8080/docs",
      "windows": {
        "command": "start http://localhost:8080/docs"
      },
      "group": "test"
    }
  ]
}
